ENV=dev
API_PREFIX=/api/v1
LOG_LEVEL=INFO
REDIS_URL=redis://redis:6379/0
POSTGRES_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/modal

GCP_PROJECT_ID=your-gcp-project
GCP_REGION=us-central1
GENAI_USE_VERTEXAI=true
GEMINI_API_KEY=
GCS_MEDIA_BUCKET=your-media-bucket
GCS_SIGNED_URL_TTL_SECONDS=3600
VERTEX_MODEL_TEXT=gemini-2.5-pro
VERTEX_MODEL_IMAGE=imagen-3.0-generate-002
VERTEX_MODEL_VIDEO=veo-3.1-generate-001
VERTEX_MODEL_TEXT_BACKUP=
VERTEX_MODEL_IMAGE_BACKUP=
VIDEOFX_ENDPOINT=https://your-videofx-service/generate
VIDEOFX_API_KEY=your-videofx-api-key
VIDEOFX_FALLBACK_ENDPOINT=
VIDEOFX_TIMEOUT_SECONDS=120
VIDEOFX_FALLBACK_DURATION_SECONDS=6
VIDEOFX_FALLBACK_RESOLUTION=1280x720

PROMPT_MAX_CHARS=2000
MODEL_INFERENCE_TIMEOUT_SECONDS=60
MEDIA_GENERATION_TIMEOUT_SECONDS=90
RETRY_MAX_ATTEMPTS=3
RETRY_BASE_DELAY_SECONDS=0.5
RETRY_MAX_DELAY_SECONDS=8.0

SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0

OTEL_ENDPOINT=
OTEL_SERVICE_NAME=modal-backend
OTEL_TRACES_SAMPLE_RATE=0.0
PROMETHEUS_ENABLED=false
PROMETHEUS_PIPELINE_PATH=/metrics/pipeline
PROMETHEUS_SYSTEM_PATH=/metrics/system

FIREBASE_PROJECT_ID=gen-lang-client-0601476483
FIREBASE_CREDENTIALS_PATH=gen-lang-client-0601476483-firebase-adminsdk-fbsvc-6810ca0a4a.json
FIREBASE_WEB_API_KEY=your-firebase-web-api-key
